<?xml version="1.0"?>
<!--
  Humanoid Robot URDF - Physical AI & Humanoid Robotics Book
  Module 1, Artifact A-002

  This URDF defines a simplified humanoid robot with:
  - Torso (base link)
  - Head (2 DOF: pan, tilt)
  - Arms (3 DOF each: shoulder pitch, shoulder roll, elbow pitch)
  - Legs (4 DOF each: hip pitch, hip roll, knee pitch, ankle pitch)

  Total: 16 DOF

  Validate with: check_urdf humanoid.urdf
  Visualize with: ros2 launch humanoid_base humanoid_bringup.launch.py
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="humanoid">

  <!-- ==================== Properties ==================== -->
  <xacro:property name="torso_height" value="0.4"/>
  <xacro:property name="torso_width" value="0.3"/>
  <xacro:property name="torso_depth" value="0.15"/>
  <xacro:property name="head_radius" value="0.1"/>
  <xacro:property name="upper_arm_length" value="0.25"/>
  <xacro:property name="forearm_length" value="0.22"/>
  <xacro:property name="upper_leg_length" value="0.3"/>
  <xacro:property name="lower_leg_length" value="0.28"/>
  <xacro:property name="foot_length" value="0.15"/>
  <xacro:property name="limb_radius" value="0.03"/>

  <!-- ==================== Materials ==================== -->
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="dark">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

  <!-- ==================== Torso ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${torso_depth} ${torso_width} ${torso_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${torso_depth} ${torso_width} ${torso_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="10.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <!-- ==================== Head ==================== -->
  <link name="head_link">
    <visual>
      <geometry>
        <sphere radius="${head_radius}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${head_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="head_pan" type="revolute">
    <parent link="base_link"/>
    <child link="head_link"/>
    <origin xyz="0 0 ${torso_height/2 + head_radius}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="2.0"/>
  </joint>

  <!-- ==================== Arm Macro ==================== -->
  <xacro:macro name="arm" params="side reflect">
    <link name="${side}_upper_arm">
      <visual>
        <origin xyz="0 0 ${-upper_arm_length/2}"/>
        <geometry>
          <cylinder radius="${limb_radius}" length="${upper_arm_length}"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-upper_arm_length/2}"/>
        <geometry>
          <cylinder radius="${limb_radius}" length="${upper_arm_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.5"/>
        <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.002"/>
      </inertial>
    </link>

    <joint name="${side}_shoulder_pitch" type="revolute">
      <parent link="base_link"/>
      <child link="${side}_upper_arm"/>
      <origin xyz="0 ${reflect * torso_width/2} ${torso_height/2 - 0.05}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-3.14" upper="3.14" effort="20" velocity="2.0"/>
    </joint>

    <link name="${side}_forearm">
      <visual>
        <origin xyz="0 0 ${-forearm_length/2}"/>
        <geometry>
          <cylinder radius="${limb_radius * 0.8}" length="${forearm_length}"/>
        </geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-forearm_length/2}"/>
        <geometry>
          <cylinder radius="${limb_radius * 0.8}" length="${forearm_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${side}_elbow_pitch" type="revolute">
      <parent link="${side}_upper_arm"/>
      <child link="${side}_forearm"/>
      <origin xyz="0 0 ${-upper_arm_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.5" upper="0.0" effort="15" velocity="2.0"/>
    </joint>
  </xacro:macro>

  <xacro:arm side="left" reflect="1"/>
  <xacro:arm side="right" reflect="-1"/>

  <!-- ==================== Leg Macro ==================== -->
  <xacro:macro name="leg" params="side reflect">
    <link name="${side}_upper_leg">
      <visual>
        <origin xyz="0 0 ${-upper_leg_length/2}"/>
        <geometry>
          <cylinder radius="${limb_radius * 1.2}" length="${upper_leg_length}"/>
        </geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-upper_leg_length/2}"/>
        <geometry>
          <cylinder radius="${limb_radius * 1.2}" length="${upper_leg_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="3.0"/>
        <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.005"/>
      </inertial>
    </link>

    <joint name="${side}_hip_pitch" type="revolute">
      <parent link="base_link"/>
      <child link="${side}_upper_leg"/>
      <origin xyz="0 ${reflect * torso_width/4} ${-torso_height/2}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="30" velocity="2.0"/>
    </joint>

    <link name="${side}_lower_leg">
      <visual>
        <origin xyz="0 0 ${-lower_leg_length/2}"/>
        <geometry>
          <cylinder radius="${limb_radius}" length="${lower_leg_length}"/>
        </geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-lower_leg_length/2}"/>
        <geometry>
          <cylinder radius="${limb_radius}" length="${lower_leg_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="2.0"/>
        <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.003"/>
      </inertial>
    </link>

    <joint name="${side}_knee_pitch" type="revolute">
      <parent link="${side}_upper_leg"/>
      <child link="${side}_lower_leg"/>
      <origin xyz="0 0 ${-upper_leg_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="2.5" effort="25" velocity="2.0"/>
    </joint>

    <link name="${side}_foot">
      <visual>
        <origin xyz="${foot_length/4} 0 0"/>
        <geometry>
          <box size="${foot_length} 0.08 0.03"/>
        </geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin xyz="${foot_length/4} 0 0"/>
        <geometry>
          <box size="${foot_length} 0.08 0.03"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${side}_ankle_pitch" type="revolute">
      <parent link="${side}_lower_leg"/>
      <child link="${side}_foot"/>
      <origin xyz="0 0 ${-lower_leg_length}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.78" upper="0.78" effort="15" velocity="2.0"/>
    </joint>
  </xacro:macro>

  <xacro:leg side="left" reflect="1"/>
  <xacro:leg side="right" reflect="-1"/>

</robot>
